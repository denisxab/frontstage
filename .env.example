# Директория с YAML-файлами каталога
CATALOG_DIR=/app/catalog

# Логирование
# Путь к лог-файлу внутри контейнера (пробрасывается через volume ./logs:/app/logs)
LOG_FILE=/app/logs/frontstage.log
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API-ключ для обычных пользователей (чтение каталога)
# Если не задан — авторизация отключена (open mode)
API_KEY_USER=key-user

# API-ключ для администратора (чтение + reload каталога)
API_KEY_ADMIN=key-admin

GIT_PLUGIN_USER=...
GIT_PLUGIN_PASSWORD=...

# Redis — персистентный кеш плагинов
# В docker-compose задаётся через environment, здесь для локального запуска
REDIS_URL=redis://frontstage-redis-1:6379